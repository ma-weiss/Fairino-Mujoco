<?xml version="1.0" encoding="utf-8"?>
<!-- MuJoCo MJCF converted from fr5_robot.urdf
     Validate: python -c "import mujoco; mujoco.MjModel.from_xml_path('fr5_robot.xml')"
     Run from this file's directory so meshes/ resolves. -->
<mujoco model="fr5_robot">
  <compiler angle="radian" meshdir="./meshes"/>

  <option gravity="0 0 -9.81" timestep="0.0005"/>

  <default>
    <joint damping="0"/>
    <default class="visual">
        <geom type="mesh" group="2" contype="0" conaffinity="0"/>
      </default>
      <default class="collision">
        <geom  group="3" mass="0" density="0"/>
      </default>
  </default>

  <asset>
    <mesh name="base_link_mesh" file="base_link.STL"/>
    <mesh name="shoulder_link_mesh" file="shoulder_link.STL"/>
    <mesh name="upperarm_link_mesh" file="upperarm_link.STL"/>
    <mesh name="forearm_link_mesh" file="forearm_link.STL"/>
    <mesh name="wrist1_link_mesh" file="wrist1_link.STL"/>
    <mesh name="wrist2_link_mesh" file="wrist2_link.STL"/>
    <mesh name="wrist3_link_mesh" file="wrist3_link.STL"/>
    <!-- <mesh name="ring" file="accent_ring.obj"/> -->
    <!-- <material name="robot" rgba="0.898 0.918 0.929 1"
            specular="0.8" shininess="0.6" reflectance="0.3"/> -->
    <material name="robot" rgba="0.92 0.92 0.92 1"
            specular="0.15"
            shininess="0.25"
            reflectance="0.03"/>        
    <material name="aluminium" rgba="0.75 0.75 0.78 1" 
            specular="0.8" shininess="0.6" reflectance="0.3"/>
    <material name="orange_accent" rgba="0.95 0.3 0.15 1" 
            specular="0.5" shininess="0.3"/>
  </asset>

  <worldbody>
    <body name="base_link" pos="0 0 0">
      <inertial pos="-0.00044457 0.0004811 0.032592" mass="1.073"
               fullinertia="0.0030836 0.0030825 0.0045209 1.5354E-05 -1.9315E-05 -1.7918E-05"/>
      <geom class="visual" name="base_link_geom"  mesh="base_link_mesh" material="robot"/>
      <geom class="collision" type="cylinder" size="0.058 0.033" pos="0 0 0.035" />
      <!-- shoulder_pan: revolute base_link -> shoulder_Link -->
      <body name="shoulder_link" pos="0 0 0" euler="0 0 0">
        <inertial pos="1.3785E-06 -0.0031495 0.14526" mass="4.64"
                 fullinertia="0.010731 0.010408 0.0081793 -8.0587E-09 -3.6773E-08 0.00012853"/>
        <joint name="shoulder_pan" type="hinge" axis="0 0 1" range="-3.0543261 3.0543261" damping="0.003" frictionloss="0.2"/>
        <geom type="mesh" name="shoulder_link_geom" mesh="shoulder_link_mesh" material="robot"/>
        <!-- shoulder_lift: revolute shoulder_link -> upperarm_link -->
        <body name="upperarm_link" pos="0 0 0.155" euler="1.570796 0 0">
          <inertial pos="-2.2928E-05 0.33278 0.084237" mass="10.08"
                   fullinertia="0.028392 0.4559 0.44974 -1.337E-07 -3.9895E-09 4.214E-08"/>
          <joint name="shoulder_lift" type="hinge" axis="0 0 1" range="-4.6251225 1.4835298" damping="0.003" frictionloss="0.2"/>
          <geom name="upperarm_link_geom" type="mesh" mesh="upperarm_link_mesh" material="robot"/>
          <!-- elbow: revolute upperarm_link -> forearm_link -->
          <body name="forearm_link" pos="-0.425 0 0" euler="0 0 0">
            <inertial pos="0.092224 -2.2928E-05 0.084237" mass="2.71"
                     fullinertia="0.0085096 0.16971 0.16854 2.1613E-06 -0.0068678 3.7086E-08"/>
            <joint name="elbow" type="hinge" axis="0 0 1" range="-2.8274333 2.8274333" damping="0.003" frictionloss="0.2"/>
            <geom name="forearm_link_geom" type="mesh" mesh="forearm_link_mesh" material="robot"/>
            <!-- wrist_1: revolute forearm_link -> wrist1_link -->
            <body name="wrist1_link" pos="-0.395 0 0" euler="0 0 0">
              <inertial pos="0.48722 -2.2928E-05 0.084237" mass="1.56"
                       fullinertia="0.00216 0.0015455 0.0019902 4.888E-09 3.1528E-08 3.7678E-05"/>
              <joint name="wrist_1" type="hinge" axis="0 0 1" range="-4.6251225 1.4835298" damping="0.003" frictionloss="0.2"/>
              <geom name="wrist1_link_geom" type="mesh" mesh="wrist1_link_mesh" material="robot"/>
              <!-- wrist_2: revolute wrist1_link -> wrist2_link -->
              <body name="wrist2_link" pos="0 0 0.1021" euler="1.570796 0 0">
                <inertial pos="-2.396E-06 0.0045906 0.099342" mass="1.56"
                         fullinertia="0.0020612 0.0014477 0.0019573 8.7064E-09 -3.4742E-08 -2.8534E-05"/>
                <joint name="wrist_2" type="hinge" axis="0 0 1" range="-3.0543261 3.0543261" damping="0.003" frictionloss="0.2"/>
                <geom name="wrist2_link_geom" type="mesh" mesh="wrist2_link_mesh" material="robot"/>
                <!-- wrist_3: revolute wrist2_link -> wrist3_link -->
                <body name="wrist3_link" pos="0 0 0.102" euler="-1.5708 0 0">
                  <inertial pos="5.8427E-06 7.5807E-05 0.079126" mass="0.36"
                           fullinertia="0.00027721 0.00027839 0.00041605 -1.8677E-09 -1.188E-07 2.2607E-07"/>
                  <joint name="wrist_3" type="hinge" axis="0 0 1" range="-3.0543261 3.0543261" damping="0.003" frictionloss="0.2"/>
                  <geom name="wrist3_link_geom" type="mesh" mesh="wrist3_link_mesh" material="aluminium"/>
                  <!-- arm_hand_joint: fixed wrist3_link -> hand_base_link -->
                  <site name="attachment_site" pos="0 0 0.100" size="0.01" rgba="1 0 0 1"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="shoulder_pan" joint="shoulder_pan" ctrllimited="true" ctrlrange="-150 150"/>
    <motor name="shoulder_lift" joint="shoulder_lift" ctrllimited="true" ctrlrange="-150 150"/>
    <motor name="elbow" joint="elbow" ctrllimited="true" ctrlrange="-150 150"/>
    <motor name="wrist_1" joint="wrist_1" ctrllimited="true" ctrlrange="-28 28"/>
    <motor name="wrist_2" joint="wrist_2" ctrllimited="true" ctrlrange="-28 28"/>
    <motor name="wrist_3" joint="wrist_3" ctrllimited="true" ctrlrange="-28 28"/>
  </actuator>

  <keyframe>
    <key name="home" qpos="0 0 0 -1.57079 0 -0.7853" ctrl="0 0 0 0 0 0"/>
  </keyframe>
</mujoco>
